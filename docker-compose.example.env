# ─────────────────────────────────────────────────────────────────────────────
# docker-compose.yml credentials — DEV ONLY.
#
# Copy this file to `.env` alongside docker-compose.yml and override the
# defaults. The compose file refuses to start if the required *_PASSWORD
# variables are unset, so this file is the single source of truth.
#
# NEVER commit `.env`. Add it to `.gitignore` in any downstream fork.
# NEVER reuse these values for any internet-exposed or production database.
#
#     cp docker-compose.example.env .env
#     # edit .env and replace the dev-only strings with unique values
#     docker compose up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_USER=reify
POSTGRES_PASSWORD=reify-dev-only-change-me
POSTGRES_DB=reify_test

# ── MySQL / MariaDB ─────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=reify-dev-only-change-me
MYSQL_USER=reify
MYSQL_PASSWORD=reify-dev-only-change-me
MYSQL_DATABASE=reify_test
